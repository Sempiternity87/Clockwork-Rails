{
  "schemaVersion": 1,
  "id": "clockwork_rail",
  "version": "${version}",
  "name": "Clockwork Rail",
  "description": "Control minecart rail junctions using Create-inspired rotation, and power minecarts using stored Stress from Create.",
  "authors": ["Chadd Klaus (@Sempiternity)"],
  "contact": {
    "homepage": "https://github.com/yourname/your-mod",
    "issues": "https://github.com/yourname/your-mod/issues",
    "sources": "https://github.com/yourname/your-mod"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.sempiternity.clockwork_rail.fabric.ClockworkRailModFabric"],
    "client": ["com.sempiternity.clockwork_rail.ClockworkRailModFabricClient"]
  },
  "mixins": ["clockwork_rail.mixins.json"],
  "accessWidener": "clockwork_rail.accesswidener",
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fabric_version}",
    "java": ">=${java_version}",
    "minecraft": ">=${minecraft_version}"
  }
}
