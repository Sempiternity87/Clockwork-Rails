{
  "schemaVersion": 1,
  "id": "clockwork_rails",
  "version": "${version}",
  "name": "Clockwork Rail",
  "description": "Control minecart rail junctions using Create-inspired rotation, and power minecarts using stored Stress from Create.",
  "authors": ["Chadd Klaus (@Sempiternity)"],
  "contact": {
    "homepage": "https://github.com/Sempiternity/Clockwork-Rails",
    "issues": "https://github.com/Sempiternity/Clockwork-Rails/issues",
    "sources": "https://github.com/Sempiternity/Clockwork-Rails"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": ["com.sempiternity.clockwork_rails.fabric.ClockworkRailsModFabric"],
    "client": ["com.sempiternity.clockwork_rails.ClockworkRailsModFabricClient"]
  },
  "mixins": ["clockwork_rails.mixins.json"],
  "accessWidener": "clockwork_rails.accesswidener",
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fabric_version}",
    "java": ">=${java_version}",
    "minecraft": ">=${minecraft_version}"
  }
}
